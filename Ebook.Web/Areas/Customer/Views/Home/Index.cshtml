@model IEnumerable<Ebook.Common.Models.Entities.Product>



<form asp-controller="Home" asp-action="Index" method="get">
    <div class="row pb-3">
        <div class="col-md-6 offset-md-3">
            <div class="input-group">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search product by name..." />
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </div>
    </div>
</form>

<div class="row pb-2">
    @foreach (var item in Model)
    {
        <div class="col-lg-3 col-md-6 mb-4 d-flex align-items-stretch">
            <div class="card w-100 p-2" style="border:1px solid #0066cc; border-radius:4px">
                <img src="@item.Picture" class="card-img-top rounded" style="object-fit: contain; height: 250px;" />
                <div class="card-body d-flex flex-column p-2">
                    <div class="px-1">
                        <p class="card-title h5 text-primary">@item.Name  </p>
                        <p class="px-1 mb-0">
                            <span style="color: green;font-weight: bold;">
                                $ @item.Price.ToString("0.00")
                            </span>
                        </p>
                    </div>
                    <div class="mt-auto pt-2">
                        <a asp-area="Customer" asp-controller="Home" asp-action="Details" class="btn btn-primary form-control" asp-route-id="@item.Id">Details</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>